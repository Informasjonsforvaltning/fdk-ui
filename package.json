{
  "name": "@fellesdatakatalog/ui",
  "version": "1.0.27",
  "description": "React UI components for Felles Datakatalog",
  "main": "dist/shared-ui.cjs",
  "module": "dist/shared-ui.es.js",
  "types": "dist/types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Informasjonsforvaltning/fdk-ui"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/shared-ui.es.js",
      "require": "./dist/shared-ui.cjs"
    },
    "./dist/styles.css": "./dist/styles.css",
    "./src/components/core/tokens.scss": "./src/components/core/tokens.scss",
    "./src/components/core/tokens": "./src/components/core/tokens.scss",
    "./src/components/core/mixins.scss": "./src/components/core/mixins.scss",
    "./src/components/core/mixins": "./src/components/core/mixins.scss",
    "./src/components/core/ds-overrides.scss": "./src/components/core/ds-overrides.scss",
    "./src/components/core/ds-overrides": "./src/components/core/ds-overrides.scss",
    "./src/components/core/reset.css": "./src/components/core/reset.css",
    "./src/components/core/reset": "./src/components/core/reset.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && npm run build:types",
    "build:types": "tsc --emitDeclarationOnly",
    "watch": "concurrently \"vite build --watch\" \"tsc --watch --emitDeclarationOnly\"",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "fellesdatakatalog"
  ],
  "author": "Felles Datakatalog",
  "license": "MIT",
  "peerDependencies": {
    "@digdir/designsystemet-react": "^1.1.9",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@digdir/designsystemet-css": "^1.9.0",
    "@digdir/designsystemet-react": "^1.9.0",
    "@digdir/designsystemet-theme": "^1.10.0",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-onboarding": "^10.2.16",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass-embedded": "^1.97.3",
    "storybook": "^10.2.16",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@navikt/aksel-icons": "^7.39.0",
    "classnames": "^2.5.1"
  },
  "resolutions": {
    "tar": ">=7.5.10",
    "glob": "^10.5.0",
    "lodash": "^4.17.23",
    "rollup": "^4.59.0",
    "immutable": "^5.1.5"
  },
  "packageManager": "yarn@4.9.4",
  "engines": {
    "node": ">=22"
  }
}
